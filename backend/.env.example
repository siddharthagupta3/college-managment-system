PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/CMS
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Comma-separated origins for your frontend pages (optional).
# Example: http://127.0.0.1:5500,http://localhost:5500
CORS_ORIGINS=

# Optional: Gemini API for AI chatbot
GEMINI_API_KEY=put_your_api_key_here
GEMINI_MODEL=gemini-1.5-flash
